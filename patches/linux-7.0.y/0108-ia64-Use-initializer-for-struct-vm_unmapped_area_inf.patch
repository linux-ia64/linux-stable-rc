From 3ead09c72d89706ba9a77291650a55c0e7ba2b46 Mon Sep 17 00:00:00 2001
From: Tomas Glozar <tglozar@gmail.com>
Date: Sat, 14 Mar 2026 22:36:07 +0100
Subject: [PATCH 108/118] ia64: Use initializer for struct
 vm_unmapped_area_info

Make ia64 arch compatible with 44bd7ace9fd6 ("mm: take placement
mappings gap into account") like the other architectures do.

Reported-by: Nathan <nsafran1217@gmail.com>
Signed-off-by: Tomas Glozar <tglozar@gmail.com>
---
 arch/ia64/kernel/sys_ia64.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/arch/ia64/kernel/sys_ia64.c b/arch/ia64/kernel/sys_ia64.c
index 9f4a579fb437..238f58f47c81 100644
--- a/arch/ia64/kernel/sys_ia64.c
+++ b/arch/ia64/kernel/sys_ia64.c
@@ -30,7 +30,7 @@ arch_get_unmapped_area (struct file *filp, unsigned long addr, unsigned long len
 	long map_shared = (flags & MAP_SHARED);
 	unsigned long align_mask = 0;
 	struct mm_struct *mm = current->mm;
-	struct vm_unmapped_area_info info;
+	struct vm_unmapped_area_info info = {};
 
 	if (len > RGN_MAP_LIMIT)
 		return -ENOMEM;
@@ -58,7 +58,6 @@ arch_get_unmapped_area (struct file *filp, unsigned long addr, unsigned long len
 		 */
 		align_mask = PAGE_MASK & (SHMLBA - 1);
 
-	info.flags = 0;
 	info.length = len;
 	info.low_limit = addr;
 	info.high_limit = TASK_SIZE;
-- 
2.25.1

