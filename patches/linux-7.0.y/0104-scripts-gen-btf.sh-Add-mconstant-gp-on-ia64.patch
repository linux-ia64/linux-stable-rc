From 956fca36885727c3371f1118e5a13189ca2f7f19 Mon Sep 17 00:00:00 2001
From: Tomas Glozar <tglozar@gmail.com>
Date: Mon, 23 Feb 2026 18:58:09 +0100
Subject: [PATCH 104/118] scripts/gen-btf.sh: Add -mconstant-gp on ia64

On ia64, the BTF object file has to be compiled with -mconstant-gp
in order to avoid linker failure.

Rather than passing the entirety of KBUILD_CFLAGS_KERNEL, pass only
-mconstant-gp in case CONFIG_IA64 is set. This might be reverted in
the future if it turns out KBUILD_CFLAGS_KERNEL also works here
(which cannot be changed without testing on other archs).

Signed-off-by: Tomas Glozar <tglozar@gmail.com>
---
 scripts/gen-btf.sh | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/scripts/gen-btf.sh b/scripts/gen-btf.sh
index 8ca96eb10a69..2da7109cb88b 100755
--- a/scripts/gen-btf.sh
+++ b/scripts/gen-btf.sh
@@ -87,7 +87,8 @@ gen_btf_o()
 	# SHF_ALLOC because .BTF will be part of the vmlinux image. --strip-all
 	# deletes all symbols including __start_BTF and __stop_BTF, which will
 	# be redefined in the linker script.
-	echo "" | ${CC} ${CLANG_FLAGS} ${KBUILD_CPPFLAGS} ${KBUILD_CFLAGS} -fno-lto -c -x c -o ${btf_data} -
+	is_enabled CONFIG_IA64 && BTF_CFLAGS="-mconstant-gp"
+	echo "" | ${CC} ${CLANG_FLAGS} ${KBUILD_CPPFLAGS} ${KBUILD_CFLAGS} ${BTF_CFLAGS} -fno-lto -c -x c -o ${btf_data} -
 	${OBJCOPY} --add-section .BTF=${ELF_FILE}.BTF \
 		--set-section-flags .BTF=alloc,readonly ${btf_data}
 	${OBJCOPY} --only-section=.BTF --strip-all ${btf_data}
