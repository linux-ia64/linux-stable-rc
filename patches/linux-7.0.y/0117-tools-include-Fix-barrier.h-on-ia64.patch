From 5d5e6a32037bf8a8fa7bdfbba49948b8fc5d635a Mon Sep 17 00:00:00 2001
From: Tomas Glozar <tglozar@gmail.com>
Date: Fri, 27 Mar 2026 19:42:31 +0100
Subject: [PATCH 117/118] tools include: Fix barrier.h on ia64

tools/arch/ia64/include/asm/barrier.h defines barrier() as ia64_mb().

Import a tool-specific version of uapi/asm/gcc_intrin.h and include it
in barrier.h to make sure ia64_mb() is available for all of its users.

Signed-off-by: Tomas Glozar <tglozar@gmail.com>
---
 tools/arch/ia64/include/asm/barrier.h         | 1 +
 tools/arch/ia64/include/uapi/asm/gcc_intrin.h | 7 +++++++
 2 files changed, 8 insertions(+)
 create mode 100644 tools/arch/ia64/include/uapi/asm/gcc_intrin.h

diff --git a/tools/arch/ia64/include/asm/barrier.h b/tools/arch/ia64/include/asm/barrier.h
index 6fffe5682713..5437a2a55f10 100644
--- a/tools/arch/ia64/include/asm/barrier.h
+++ b/tools/arch/ia64/include/asm/barrier.h
@@ -15,6 +15,7 @@
 #define _TOOLS_LINUX_ASM_IA64_BARRIER_H
 
 #include <linux/compiler.h>
+#include <uapi/asm/gcc_intrin.h>
 
 /*
  * Macros to force memory ordering.  In these descriptions, "previous"
diff --git a/tools/arch/ia64/include/uapi/asm/gcc_intrin.h b/tools/arch/ia64/include/uapi/asm/gcc_intrin.h
new file mode 100644
index 000000000000..755472007762
--- /dev/null
+++ b/tools/arch/ia64/include/uapi/asm/gcc_intrin.h
@@ -0,0 +1,7 @@
+/* SPDX-License-Identifier: GPL-2.0 WITH Linux-syscall-note */
+#ifndef _ASM_IA64_GCC_INTRIN_H
+#define _ASM_IA64_GCC_INTRIN_H
+
+#define ia64_mf()	asm volatile ("mf" ::: "memory")
+
+#endif /* _ASM_IA64_GCC_INTRIN_H */
-- 
