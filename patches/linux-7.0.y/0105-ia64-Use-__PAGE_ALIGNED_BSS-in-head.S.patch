From 26823e7d59ce3dd86c0e26c8d5caeb54a005c475 Mon Sep 17 00:00:00 2001
From: Tomas Glozar <tglozar@gmail.com>
Date: Mon, 23 Feb 2026 20:07:20 +0100
Subject: [PATCH 105/118] ia64: Use __PAGE_ALIGNED_BSS in head.S

Move empty_zero_page and swapper_pg_dir into bss segment from data
segment to save some space in the vmlinux ELF file.

Signed-off-by: Tomas Glozar <tglozar@gmail.com>
---
 arch/ia64/kernel/head.S | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/ia64/kernel/head.S b/arch/ia64/kernel/head.S
index 85c8a57da402..5e9cb4c762df 100644
--- a/arch/ia64/kernel/head.S
+++ b/arch/ia64/kernel/head.S
@@ -166,7 +166,7 @@ RestRR:											\
 	mov _tmp2=((ia64_rid(IA64_REGION_ID_KERNEL, (num<<61)) << 8) | (pgsize << 2) | vhpt);; \
 	mov rr[_tmp1]=_tmp2
 
-	__PAGE_ALIGNED_DATA
+	__PAGE_ALIGNED_BSS
 
 	.global empty_zero_page
 EXPORT_SYMBOL_GPL(empty_zero_page)
-- 
2.25.1

